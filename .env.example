# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server port (default: 5000)
PORT=5000

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/zenab

# Allowed frontend origin for CORS (e.g. https://yourapp.com in production)
FRONTEND_URL=http://localhost:5173

# Power BI Streaming Dataset push URL (optional)
# Get this from: Power BI → Workspace → + New → Streaming dataset → API
POWERBI_PUSH_URL=
